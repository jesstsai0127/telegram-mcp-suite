# === 必填 ===

# 從 @BotFather 建立 bot 拿到的 token（TELEGRAM_ASSISTANT_BOT_TOKEN 優先，TELEGRAM_BOT_TOKEN 是備援名稱）
TELEGRAM_ASSISTANT_BOT_TOKEN=

# Notion internal integration token（https://www.notion.so/my-integrations）
# 建立後，記得在 Notion 裡把要用的頁面分享給這個 integration
NOTION_API_KEY=

# === 選填：意圖解析用的 AI（至少要有一組能動，否則自然語言輸入無法分類）===

OLLAMA_HOST=http://localhost:11434
OLLAMA_INTENT_MODEL=gemma4:12b
AI_GATEWAY_URL=
AI_GATEWAY_KEY=

# === 選填：n8n / 通知閘道（沒有的話對應功能會停用，不影響核心功能）===

N8N_MESSAGE_WEBHOOK=http://localhost:5678/webhook/axis-message
NOTIFICATION_GATEWAY_URL=http://localhost:3003/notify

# === 選填：finance-tracker 整合（沒跑這個服務就留空，/net_worth 指令會顯示連線失敗）===

FINANCE_TRACKER_URL=http://127.0.0.1:3004
FINANCE_TRACKER_UI_URL=

# === 選填：時區/語系（預設台灣，換到別的地區時區只需要改這裡）===

TIMEZONE=Asia/Taipei
TIMEZONE_OFFSET=+08:00
LOCALE=zh-TW

# === 選填：port（同一台機器要同時跑兩個 instance，例如正式+測試環境，才需要改）===

SKILL_PORT=3001
BRIDGE_PORT=4141
TODAY_PORT=3005
TODAY_TAILSCALE_IP=
TODAY_UI_URL=
PROJECTS_UI_URL=

# === 選填：檔案路徑覆寫（獨立測試環境用，指到跟正式環境不同的檔案，避免互相污染）===

ENV_PATH=
CHAT_ID_FILE_PATH=
NOTION_DBS_CONFIG_PATH=
PERSONA_PATH=
PERSONA_LOG_PATH=
SKILL_REGISTRY_PATH=
